# DataForSEO API credentials (https://app.dataforseo.com/api-access)
# Required for live analysis. Without them the app runs in demo mode.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Notion integration (optional - enables "Log to Notion")
# Create an internal integration at https://www.notion.so/my-integrations,
# share your target database with it, and paste the database ID below.
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Server port (optional)
PORT=4000
